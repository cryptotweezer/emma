# ── SERVIDOR ──────────────────────────────────
CONTABO_IP=
CONTABO_ROOT_PASSWORD=

# ── TELEGRAM ──────────────────────────────────
TELEGRAM_BOT_TOKEN=          # token de @BotFather para @emma_openclawbot
TELEGRAM_USER_ID=            # tu Telegram user ID (conseguir con @userinfobot)

# ── BOT CONFIG ────────────────────────────────
BOT_INTERVAL=300             # segundos entre ciclos (default: 5 min)
BOT_MIN_EDGE=0.08            # edge mínimo para tradear (default: 8%)
BOT_MAX_KELLY=0.15           # fracción máxima Kelly (default: 15%)
BOT_MAX_DAILY_LOSS=0.05      # stop si pérdida diaria > 5%
BOT_MAX_DRAWDOWN=0.15        # stop si drawdown total > 15%
BOT_MAX_POSITIONS=5          # máx posiciones abiertas simultáneas
DISCORD_WEBHOOK_URL=         # Sprint 2 — dejar vacío por ahora

# ── TRADING — SIMMER ──────────────────────────
SIMMER_API_KEY=              # simmer.markets — paper trading $SIM

# ── TRADING — POLYMARKET ──────────────────────
POLYMARKET_PRIVATE_KEY=      # wallet EOA para Polygon
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_API_KEY=          # Sprint 2 — dinero real
POLYMARKET_API_SECRET=       # Sprint 2
POLYMARKET_API_PASSPHRASE=   # Sprint 2
POLYMARKET_FUNDER=           # Sprint 2

# ── AI MODELS ─────────────────────────────────
GROQ_API_KEY=                # llama 3.3 70B — principal
OPENROUTER_API_KEY=          # fallback si Groq falla
NVIDIA_API_KEY=              # Kimi K2.5
GEMINI_API_KEY=              # embeddings memoria semántica Emma

# ── SEÑALES ───────────────────────────────────
METACULUS_API_KEY=           # /api2/questions/ — señal primaria 60%
MANIFOLD_API_KEY=            # /v0/markets — señal secundaria 40%

# ── BLOCKCHAIN ────────────────────────────────
ALCHEMY_API_KEY=             # Polygon mainnet node
ALCHEMY_NODE=                # URL completa del nodo Alchemy
CHAINSTACK_NODE=             # nodo alternativo Chainstack
POLYCLAW_PRIVATE_KEY=        # clave para PolyClaw
